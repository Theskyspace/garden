---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Akash Joshi — Founding Engineer',
  description = 'Founding engineer building AI products. Currently at Equal Identity in India\'s Account Aggregator framework.',
} = Astro.props;

const path = Astro.url.pathname;
const isActive = (p: string) => path === p || (p !== '/' && path.startsWith(p));

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
}

const { wide = false } = Astro.props;

const navLinks = [
  { href: '/writing', label: 'writing' },
  { href: '/work', label: 'work' },
  { href: '/projects', label: 'projects' },
  { href: '/about', label: 'about' },
];
---

<!doctype html>
<html lang="en" class="bg-neutral-950 text-neutral-100">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0a0a0a" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-neutral-950 font-sans antialiased text-[15px] leading-7 text-neutral-300 selection:bg-neutral-100 selection:text-neutral-900">
    <div class={`mx-auto px-6 py-10 md:py-16 ${wide ? 'max-w-3xl' : 'max-w-2xl'}`}>
      <nav class="mb-14 flex items-center justify-between text-sm text-neutral-400">
        <a
          href="/"
          class="font-medium text-neutral-100 hover:text-neutral-400 transition-colors"
          aria-current={isActive('/') && path === '/' ? 'page' : undefined}
        >
          akash joshi
        </a>
        <div class="flex items-center gap-5">
          {navLinks.map((l) => (
            <a
              href={l.href}
              class={`transition-colors ${isActive(l.href) ? 'text-neutral-100' : 'hover:text-neutral-100'}`}
              aria-current={isActive(l.href) ? 'page' : undefined}
            >
              {l.label}
            </a>
          ))}
        </div>
      </nav>
      <slot />
      <footer class="mt-24 pt-8 border-t border-neutral-900 flex flex-wrap items-center justify-between gap-3 text-xs text-neutral-500">
        <span>akash joshi · mumbai · {new Date().getFullYear()}</span>
        <span class="flex items-center gap-4">
          <a href="https://github.com/theskyspace" class="hover:text-neutral-200 transition-colors">github</a>
          <a href="https://linkedin.com/in/theskyspace" class="hover:text-neutral-200 transition-colors">linkedin</a>
          <a href="mailto:theskyspacedev@gmail.com" class="hover:text-neutral-200 transition-colors">theskyspacedev@gmail.com</a>
          <a href="/resume" class="hover:text-neutral-200 transition-colors">resume</a>
        </span>
      </footer>
    </div>
  </body>
</html>
