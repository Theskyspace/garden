---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import MaturityBadge from '../../components/MaturityBadge.astro';
import { formatDate, relativeFromNow } from '../../lib/format';

const notes = (await getCollection('writing', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.tended.getTime() - a.data.tended.getTime()
);

const topics = Array.from(new Set(notes.flatMap((n) => n.data.topics))).sort();
const maturities = ['evergreen', 'growing', 'seedling'] as const;
const counts = {
  all: notes.length,
  ...Object.fromEntries(maturities.map((m) => [m, notes.filter((n) => n.data.maturity === m).length])),
};
---

<Base title="Writing — Akash Joshi" description="Notes, essays, and seedlings. Part garden, part profile.">
  <header class="mb-10">
    <h1 class="text-2xl md:text-3xl font-medium tracking-tight text-neutral-100">Writing</h1>
    <p class="mt-3 max-w-prose text-neutral-400">
      A garden, not a magazine. <MaturityBadge maturity="seedling" /> are half-formed,
      <MaturityBadge maturity="growing" /> are being actively edited,
      <MaturityBadge maturity="evergreen" /> are the version I&rsquo;d link a stranger to.
      Everything shows when it was last tended.
    </p>
  </header>

  <div class="mb-10 flex flex-wrap items-center gap-x-2 gap-y-3" data-filter-bar>
    <span class="text-[10.5px] uppercase tracking-[0.18em] text-neutral-600 mr-1">maturity</span>
    <button
      class="filter-chip data-[active=true]:bg-neutral-100 data-[active=true]:text-neutral-900 data-[active=true]:border-neutral-100 text-xs uppercase tracking-[0.14em] border border-neutral-800 text-neutral-400 hover:text-neutral-100 hover:border-neutral-600 rounded-full px-3 py-1 transition-colors"
      data-filter-maturity="all"
      data-active="true"
    >
      all <span class="text-neutral-600 ml-1 tabular-nums">{counts.all}</span>
    </button>
    {maturities.map((m) => (
      <button
        class="filter-chip data-[active=true]:bg-neutral-100 data-[active=true]:text-neutral-900 data-[active=true]:border-neutral-100 text-xs uppercase tracking-[0.14em] border border-neutral-800 text-neutral-400 hover:text-neutral-100 hover:border-neutral-600 rounded-full px-3 py-1 transition-colors"
        data-filter-maturity={m}
      >
        {m} <span class="text-neutral-600 ml-1 tabular-nums">{counts[m]}</span>
      </button>
    ))}
    <span class="mx-2 text-neutral-800">·</span>
    <span class="text-[10.5px] uppercase tracking-[0.18em] text-neutral-600 mr-1">topic</span>
    <button
      class="filter-chip data-[active=true]:bg-neutral-100 data-[active=true]:text-neutral-900 data-[active=true]:border-neutral-100 text-xs uppercase tracking-[0.14em] border border-neutral-800 text-neutral-400 hover:text-neutral-100 hover:border-neutral-600 rounded-full px-3 py-1 transition-colors"
      data-filter-topic="all"
      data-active="true"
    >
      all
    </button>
    {topics.map((t) => (
      <button
        class="filter-chip data-[active=true]:bg-neutral-100 data-[active=true]:text-neutral-900 data-[active=true]:border-neutral-100 text-xs uppercase tracking-[0.14em] border border-neutral-800 text-neutral-400 hover:text-neutral-100 hover:border-neutral-600 rounded-full px-3 py-1 transition-colors"
        data-filter-topic={t}
      >
        {t}
      </button>
    ))}
  </div>

  <ul class="divide-y divide-neutral-900" data-notes-list>
    {notes.map((n) => (
      <li
        data-note
        data-maturity={n.data.maturity}
        data-topics={n.data.topics.join(',')}
      >
        <a href={`/writing/${n.id}`} class="group block py-5 -mx-2 px-2 rounded transition-colors hover:bg-neutral-900/40">
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <h2 class="text-[16px] text-neutral-100 group-hover:text-white">{n.data.title}</h2>
            <span class="text-xs tabular-nums text-neutral-500 whitespace-nowrap">
              tended {relativeFromNow(n.data.tended)}
            </span>
          </div>
          <p class="mt-1.5 text-sm text-neutral-400">{n.data.description}</p>
          <div class="mt-2.5 flex flex-wrap items-center gap-x-3 gap-y-1">
            <MaturityBadge maturity={n.data.maturity} />
            {n.data.topics.map((t) => (
              <span class="text-[10.5px] uppercase tracking-[0.16em] text-neutral-600">#{t}</span>
            ))}
            <span class="text-[10.5px] uppercase tracking-[0.16em] text-neutral-700">created {formatDate(n.data.created, { mode: 'short' })}</span>
          </div>
        </a>
      </li>
    ))}
  </ul>

  <p data-empty hidden class="mt-12 text-center text-sm text-neutral-500">
    Nothing in this slice of the garden yet.
  </p>
</Base>

<script>
  const bar = document.querySelector('[data-filter-bar]') as HTMLElement | null;
  const list = document.querySelector('[data-notes-list]') as HTMLElement | null;
  const empty = document.querySelector('[data-empty]') as HTMLElement | null;
  if (bar && list) {
    let mat = 'all';
    let topic = 'all';
    const apply = () => {
      let shown = 0;
      list.querySelectorAll<HTMLElement>('[data-note]').forEach((el) => {
        const m = el.dataset.maturity!;
        const ts = (el.dataset.topics || '').split(',').filter(Boolean);
        const matchM = mat === 'all' || m === mat;
        const matchT = topic === 'all' || ts.includes(topic);
        const show = matchM && matchT;
        el.hidden = !show;
        if (show) shown++;
      });
      if (empty) empty.hidden = shown !== 0;
    };
    bar.querySelectorAll<HTMLButtonElement>('[data-filter-maturity]').forEach((b) => {
      b.addEventListener('click', () => {
        bar.querySelectorAll<HTMLButtonElement>('[data-filter-maturity]').forEach((x) => (x.dataset.active = 'false'));
        b.dataset.active = 'true';
        mat = b.dataset.filterMaturity!;
        apply();
      });
    });
    bar.querySelectorAll<HTMLButtonElement>('[data-filter-topic]').forEach((b) => {
      b.addEventListener('click', () => {
        bar.querySelectorAll<HTMLButtonElement>('[data-filter-topic]').forEach((x) => (x.dataset.active = 'false'));
        b.dataset.active = 'true';
        topic = b.dataset.filterTopic!;
        apply();
      });
    });
  }
</script>
