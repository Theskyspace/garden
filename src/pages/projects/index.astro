---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  projects.map(async (p) => ({ entry: p, Content: (await render(p)).Content }))
);
---

<Base title="Projects — Akash Joshi" description="Side projects, hackathon work, and self-imposed sprints.">
  <header class="mb-12">
    <h1 class="text-2xl md:text-3xl font-medium tracking-tight text-neutral-100">Projects</h1>
    <p class="mt-3 max-w-prose text-neutral-400">
      Things I built outside the day job. Mostly self-imposed constraints to prove a point
      to myself.
    </p>
  </header>

  <ol class="space-y-12">
    {rendered.map(({ entry, Content }) => (
      <li>
        <header class="mb-4">
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <h2 class="text-lg font-medium text-neutral-100">{entry.data.name}</h2>
            <div class="flex items-baseline gap-3 text-xs text-neutral-500">
              <span class="tabular-nums">{entry.data.year}</span>
              {entry.data.href && entry.data.href !== '#' && (
                <a href={entry.data.href} class="hover:text-neutral-100 transition-colors">{entry.data.label} →</a>
              )}
            </div>
          </div>
          <p class="mt-1 text-sm text-neutral-400">{entry.data.blurb}</p>
        </header>
        <div class="prose-note">
          <Content />
        </div>
      </li>
    ))}
  </ol>
</Base>

<style is:global>
  .prose-note { color: rgb(212 212 212); font-size: 15px; line-height: 1.75; }
  .prose-note > * + * { margin-top: 0.9em; }
  .prose-note a { color: rgb(245 245 245); text-decoration: underline; text-decoration-color: rgb(64 64 64); text-underline-offset: 3px; transition: text-decoration-color 0.15s; }
  .prose-note a:hover { text-decoration-color: rgb(245 245 245); }
  .prose-note strong { color: rgb(245 245 245); font-weight: 500; }
  .prose-note em { color: rgb(229 229 229); font-style: italic; }
</style>
