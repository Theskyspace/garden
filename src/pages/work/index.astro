---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { url } from '../../lib/format';

const work = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  work.map(async (entry) => ({ entry, Content: (await render(entry)).Content }))
);
---

<Base title="Work — Akash Joshi" description="Three roles, told as narratives. The resume version is at /resume.">
  <header class="mb-12">
    <h1 class="text-2xl md:text-3xl font-medium tracking-tight text-neutral-100">Work</h1>
    <p class="mt-3 max-w-prose text-neutral-400">
      Three roles, told as stories — what I owned, what broke, what I learned. For the
      dense bullet-format version, see <a href={url('/resume')} class="text-neutral-100 underline decoration-neutral-700 hover:decoration-neutral-100 transition">/resume</a>.
    </p>
  </header>

  <ol class="space-y-16">
    {rendered.map(({ entry, Content }) => (
      <li id={entry.id} class="scroll-mt-20">
        <header class="mb-5 pb-4 border-b border-neutral-900">
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <div class="flex items-baseline gap-2">
              <h2 class="text-xl font-medium text-neutral-100">
                {entry.data.href ? (
                  <a href={entry.data.href} class="hover:text-white transition-colors">{entry.data.company} <span class="text-neutral-700">↗</span></a>
                ) : (
                  entry.data.company
                )}
              </h2>
              {entry.data.current && (
                <span class="text-[10px] uppercase tracking-[0.16em] text-emerald-300/80 border border-emerald-400/20 rounded-full px-1.5 py-px">current</span>
              )}
            </div>
            <p class="text-sm tabular-nums text-neutral-500 whitespace-nowrap">{entry.data.period}</p>
          </div>
          <p class="mt-1 text-sm text-neutral-500">
            {entry.data.role} · {entry.data.sector}{entry.data.location && ` · ${entry.data.location}`}
          </p>
        </header>
        <div class="prose-note">
          <Content />
        </div>
      </li>
    ))}
  </ol>
</Base>

<style is:global>
  .prose-note { color: rgb(212 212 212); font-size: 15.5px; line-height: 1.75; }
  .prose-note > * + * { margin-top: 1em; }
  .prose-note p { color: rgb(212 212 212); }
  .prose-note a { color: rgb(245 245 245); text-decoration: underline; text-decoration-color: rgb(64 64 64); text-underline-offset: 3px; transition: text-decoration-color 0.15s; }
  .prose-note a:hover { text-decoration-color: rgb(245 245 245); }
  .prose-note strong { color: rgb(245 245 245); font-weight: 500; }
  .prose-note em { color: rgb(229 229 229); font-style: italic; }
</style>
